{
  "manifest_version": 3,
  "name": "Neo2DB",
  "version": "1.0",
  "description": "Auto-fill Douban Music submission from NeoDB.",
  "icons": {
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting", "storage", "webNavigation"],
  "host_permissions": ["https://neodb.social/*", "https://music.douban.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://neodb.social/album/*"],
      "js": ["content.js"]
    }
  ]
}
